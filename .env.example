# Import keys - 敏感配置模板
# 复制此文件为 .impKey，然后填入实际值

# ============================================================
# LLM Provider Configuration (支持 N 个动态 Provider)
# ============================================================
# 
# Provider 1 (主配置):
#   方式 A: 使用无后缀变量 (向后兼容)
#     LLM_API_KEY=xxx
#     LLM_BASE_URL=xxx
#     LLM_MODEL=xxx
#   
#   方式 B: 使用 _1 后缀 (推荐)
#     LLM_API_KEY_1=xxx
#     LLM_BASE_URL_1=xxx
#     LLM_MODEL_1=xxx
#
# Provider 2+ (备用配置，主配置失败时自动切换):
#     LLM_API_KEY_2=xxx
#     LLM_BASE_URL_2=xxx
#     LLM_MODEL_2=xxx
#
#     LLM_API_KEY_3=xxx
#     LLM_BASE_URL_3=xxx
#     LLM_MODEL_3=xxx
#
# 注意: Provider 检测顺序为 1, 2, 3... 遇到第一个空缺即停止
# ============================================================

# 主 LLM 配置 (Provider 1)
LLM_API_KEY={your_api_key}
LLM_BASE_URL={your_base_url}
LLM_MODEL={your_model}

# 备用 LLM 配置 (Provider 2, 可选)
# LLM_API_KEY_2=
# LLM_BASE_URL_2=
# LLM_MODEL_2=

# 更多备用配置 (Provider 3+, 可选)
# LLM_API_KEY_3=
# LLM_BASE_URL_3=
# LLM_MODEL_3=

# ============================================================
# 数据库配置
# ============================================================
DB_TYPE=sqlite
DB_URL=sqlite:///data/demo_db/sales.db
ALLOWED_TABLES=orders,products,order_items,customers

# 向量数据库（Round 5: 迁移到 .deploy/ 目录）
VECTOR_DB_PATH=./.deploy/chroma

# SQL 执行配置
SQL_MAX_ROWS=200
SQL_QUERY_TIMEOUT=15
READONLY_MODE=true

# ============================================================
# API 认证配置 (可选)
# ============================================================
API_KEY_ENABLED=false
API_KEYS=
API_KEY_HEADER=X-API-Key

# ============================================================
# 功能开关
# ============================================================
ENABLE_HISTORY=true
ENABLE_CHART=true
ENABLE_CLARIFICATION=false

# ============================================================
# 应用配置
# ============================================================
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
