APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# LLM Provider 配置
LLM_PROVIDER=bailian_code_plan
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# 百炼 Code Plan 配置
BAILIAN_API_KEY=
BAILIAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
BAILIAN_MODEL=glm-5

# Astron (xfyun-maas) 配置
ASTRON_API_KEY=
ASTRON_BASE_URL=https://maas-api.xfyun.cn/v1
ASTRON_MODEL=astron-code-latest

# 数据库类型: sqlite, mysql, postgresql
DB_TYPE=sqlite

# SQLite 数据库 URL
DB_URL=sqlite:///data/demo_db/sales.db

# MySQL 配置（如果使用 MySQL）
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=your_user
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=your_database

# 向量数据库路径
VECTOR_DB_PATH=./data/chroma

# SQL 执行配置
SQL_MAX_ROWS=200
SQL_QUERY_TIMEOUT=15
READONLY_MODE=true

# 允许的表名白名单（逗号分隔）
ALLOWED_TABLES=orders,products,order_items,customers

# API Key 认证配置
API_KEY_ENABLED=false
API_KEYS=
API_KEY_HEADER=X-API-Key

# 功能开关
ENABLE_HISTORY=true
ENABLE_CHART=true
ENABLE_CLARIFICATION=false