# Import keys - 敏感配置模板
# 复制此文件为 .impKey，然后填入实际值

# 主 LLM 配置
LLM_API_KEY={your_api_key}
LLM_BASE_URL={your_base_url}
LLM_MODEL={your_model}

# 备用 LLM 配置（可选，primary 失败时自动切换）
# LLM_API_KEY_2=
# LLM_BASE_URL_2=
# LLM_MODEL_2=

# 数据库
DB_TYPE=sqlite
DB_URL=sqlite:///data/demo_db/sales.db
ALLOWED_TABLES=orders,products,order_items,customers

# 向量数据库
VECTOR_DB_PATH=./data/chroma

# SQL 执行配置
SQL_MAX_ROWS=200
SQL_QUERY_TIMEOUT=15
READONLY_MODE=true

# API Key 认证（可选）
API_KEY_ENABLED=false
API_KEYS=
API_KEY_HEADER=X-API-Key

# 功能开关
ENABLE_HISTORY=true
ENABLE_CHART=true
ENABLE_CLARIFICATION=false

# 应用配置
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
